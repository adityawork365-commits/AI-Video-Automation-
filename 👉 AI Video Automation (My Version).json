        "specifyBody": "json",
        "jsonBody": "={\n  \"template_id\": \"5a0f37b7-9733-45fc-9c2d-30bc3630168f\",\n  \"modifications\": {\n    \"Video.source\": \"https://creatomate.com/files/assets/7347c3b7-e1a8-4439-96f1-f3dfc95c3d28\",\n    \"Text-1.text\": \"{{ $json.jobs[0] }}\",\n    \"Text-2.text\": \"{{ $json.jobs[1] }}\",\n    \"Text-3.text\": \"{{ $json.jobs[2] }}\",\n    \"Text-4.text\": \"{{ $json.jobs[3] }}\"\n  }\n}",
