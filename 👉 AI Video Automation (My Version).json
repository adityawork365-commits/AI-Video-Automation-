    {
      "parameters": {
        "jsCode": "const items = $input.all();\n// Har item se description nikalna\nlet jobs = items.map(item => item.json.description).filter(j => j !== null);\n\n// Agar jobs 4 se kam hain toh extra text add karna taaki error na aaye\nwhile (jobs.length < 4) {\n  jobs.push(\"Check JobAlertIndia for more updates!\");\n}\n\nreturn [\n  {\n    json: {\n      jobs: jobs\n    }\n  }\n];"
      },
